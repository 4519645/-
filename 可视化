<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>汽车性能交互式探索 (作业3)</title>
  <!-- 引入 Vega, Vega-Lite 和 Vega-Embed 库 -->
  <script src="https://cdn.jsdelivr.net/npm/vega@5.22.1"></script>
  <script src="https://cdn.jsdelivr.net/npm/vega-lite@5.6.0"></script>
  <script src="https://cdn.jsdelivr.net/npm/vega-embed@6.21.0"></script>
  <style>
    body { 
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
      padding: 30px; 
      background-color: #f4f7f6; 
      line-height: 1.6;
    }
    h1 { color: #2c3e50; margin-bottom: 10px; }
    .instructions { 
      background: #fff; 
      padding: 15px 20px; 
      border-left: 5px solid #3498db; 
      border-radius: 4px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.05);
      margin-bottom: 25px;
      max-width: 900px;
    }
    .instructions strong { color: #2980b9; }
    #vis { 
      padding: 20px; 
      background: white; 
      border-radius: 12px; 
      box-shadow: 0 10px 25px rgba(0,0,0,0.1); 
      display: inline-block;
    }
    .footer { margin-top: 20px; color: #888; font-size: 0.9em; }
  </style>
</head>
<body>

  <h1>汽车性能与产地交互式可视化探索</h1>
  
  <div class="instructions">
    <p><strong>交互指南：</strong></p>
    <ul>
      <li><strong>图例过滤（关键修正）：</strong> 点击右侧图例中的产地名称（如 <strong>USA</strong>），可高亮该产地车辆并过滤右侧统计图（按住 Shift 可多选）。</li>
      <li><strong>平移与缩放：</strong> 在左图使用鼠标滚轮进行缩放，点击并拖拽背景进行平移。</li>
      <li><strong>刷选联动：</strong> 在左图拖拽鼠标绘制矩形框（Brush），右侧柱状图将实时计算选中区域内车辆的平均气缸数。</li>
      <li><strong>按需详情：</strong> 悬停在任何数据点上，即可查看车型名称、年份及具体参数。</li>
    </ul>
  </div>

  <!-- 渲染可视化的容器 -->
  <div id="vis"></div>

  <div class="footer">
    数据来源: Vega-datasets (cars.json) | 技术栈: Vega-Lite, JavaScript
  </div>

  <script>
    // Vega-Lite 完整交互配置
    const vlSpec = {
      "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
      "data": {"url": "https://raw.githubusercontent.com/vega/vega-datasets/master/data/cars.json"},
      "hconcat": [
        {
          "width": 450,
          "height": 400,
          "title": "马力 vs 每加仑英里数 (支持缩放、框选、图例过滤)",
          "params": [
            {
              "name": "brush",
              "select": "interval" // 矩形框选参数
            },
            {
              "name": "grid",
              "select": "interval",
              "bind": "scales" // 缩放平移参数
            },
            {
              "name": "leg_sel",
              "select": {"type": "point", "fields": ["Origin"]},
              "bind": "legend" // 将选择绑定到图例
            }
          ],
          "mark": {"type": "circle", "size": 60, "cursor": "pointer"},
          "encoding": {
            "x": {"field": "Horsepower", "type": "quantitative", "title": "马力 (HP)"},
            "y": {"field": "Miles_per_Gallon", "type": "quantitative", "title": "油耗 (MPG)"},
            "color": {
              "condition": {
                "param": "brush",
                "field": "Origin",
                "type": "nominal",
                "title": "产地"
              },
              "value": "#ddd" // 未被框选时的颜色
            },
            "opacity": {
              "condition": {"param": "leg_sel", "value": 0.8},
              "value": 0.1 // 未被图例选中的点变透明
            },
            "tooltip": [
              {"field": "Name", "type": "nominal", "title": "车型"},
              {"field": "Year", "type": "temporal", "timeUnit": "year", "title": "生产年份"},
              {"field": "Horsepower", "type": "quantitative", "title": "马力"},
              {"field": "Miles_per_Gallon", "type": "quantitative", "title": "油耗"},
              {"field": "Origin", "type": "nominal", "title": "产地"}
            ]
          }
        },
        {
          "width": 250,
          "height": 400,
          "title": "选中区域平均气缸数",
          "mark": {"type": "bar", "cornerRadiusEnd": 4},
          "transform": [
            {"filter": {"param": "brush"}},   // 响应左图框选
            {"filter": {"param": "leg_sel"}} // 响应图例点击
          ],
          "encoding": {
            "x": {"field": "Origin", "type": "nominal", "title": "产地", "axis": {"labelAngle": 0}},
            "y": {
              "field": "Cylinders", 
              "type": "quantitative", 
              "aggregate": "mean", 
              "title": "平均气缸数",
              "scale": {"domain": [0, 8]}
            },
            "color": {"field": "Origin", "type": "nominal", "legend": null},
            "tooltip": [
              {"field": "Origin", "type": "nominal", "title": "产地"},
              {"field": "Cylinders", "type": "quantitative", "aggregate": "mean", "title": "平均气缸数", "format": ".2f"}
            ]
          }
        }
      ],
      "config": {
        "view": {"stroke": "transparent"},
        "axis": {"gridColor": "#f0f0f0", "titleFontSize": 12}
      }
    };

    // 嵌入图表
    vegaEmbed('#vis', vlSpec, {"actions": true}).catch(console.error);
  </script>
</body>
</html> 
